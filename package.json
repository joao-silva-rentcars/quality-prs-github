{
  "name": "quality-prs-github",
  "version": "1.0.0",
  "description": "Repository to bring the necessary PRs for quality analysis.",
  "private": true,
  "main": "index.js",
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev:backend": "npm run start:dev -w apps/backend",
    "dev:frontend": "npm run dev -w apps/frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npm run build -w apps/backend && npm run build -w apps/frontend",
    "lint": "npm run lint -w apps/backend && npm run lint -w apps/frontend",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joao-silva-rentcars/quality-prs-github.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/joao-silva-rentcars/quality-prs-github/issues"
  },
  "homepage": "https://github.com/joao-silva-rentcars/quality-prs-github#readme",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
